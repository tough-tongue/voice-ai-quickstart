# =============================================================================
# ToughTongue AI Marketing Demo — Environment Variables
# Copy to .env.local and fill in the values.
# =============================================================================

# ── ToughTongue AI ─────────────────────────────────────────────────────────────
# Your API token from https://app.toughtongueai.com/developer
# Server-side only — never use NEXT_PUBLIC_ prefix for this key.
TOUGHTONGUE_API_TOKEN=your_api_token_here

# Optional: override the TTAI API base URL (default: https://app.toughtongueai.com/api/public)
# TOUGHTONGUE_API_BASE=https://app.toughtongueai.com/api/public

# ── App ────────────────────────────────────────────────────────────────────────
# Canonical URL of your deployment (used in sitemap + robots.txt)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# Set to "true" on dev/preview deployments to block all search crawlers
NEXT_PUBLIC_IS_DEV=false

# ── Admin ──────────────────────────────────────────────────────────────────────
# Password for the /admin dashboard
# IMPORTANT: Change this before deploying publicly.
NEXT_PUBLIC_ADMIN_PASSWORD=changeme-in-prod
